# Copy to .env and fill in your values
# cp .env.example .env

# ── Orchestrator ───────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Lume Client ────────────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:8000
MOCK_ACTIONS=true         # set false inside real Lume VM

# ── Ollama (Step 8) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Postgres (Step 10) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://leoclaw:leoclaw@localhost:5432/leoclaw
